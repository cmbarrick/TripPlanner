{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    "MediaStorage": "<connection string of the media storage account (queue + blobs)>",
    "Storage:MediaContainer": "media",

    "Speech:Endpoint": "https://<region>.api.cognitive.microsoft.com",
    "Speech:Key": "<azure ai speech key>",

    "Api:BaseUrl": "https://app-wander-dev-azgnto.azurewebsites.net",
    "Api:CallbackKey": "<shared key matching the API's Functions:CallbackKey>"
  }
}
